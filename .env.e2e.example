# Copy to .env.e2e for local e2e runs: cp .env.e2e.example .env.e2e

NODE_ENV=test

# PostgreSQL (postgres-e2e service — port 5433 avoids clash with dev on 5432)
POSTGRES_USER=nest
POSTGRES_PASSWORD=nest
POSTGRES_DB=nest
POSTGRES_PORT=5433

DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_USER=nest
DATABASE_PASSWORD=nest
DATABASE_NAME=nest

# Redis (redis-e2e service — port 6380 avoids clash with dev on 6379)
REDIS_HOST=localhost
REDIS_PORT=6380

# AWS S3 (use real credentials or mock in e2e tests)
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_SIGNED_URL_EXPIRES=3600

# File upload
FILE_MAX_SIZE=5242880
UPLOAD_TMP_DIR=./tmp/e2e-uploads
IMAGE_MAX_WIDTH=4000
IMAGE_MIN_WIDTH=10
IMAGE_MAX_HEIGHT=4000
IMAGE_MIN_HEIGHT=10
