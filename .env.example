# Application
PORT=3000
NODE_ENV=development

# PostgreSQL (used by the postgres service)
POSTGRES_USER=nest
POSTGRES_PASSWORD=nest
POSTGRES_DB=nest
POSTGRES_PORT=5432

# Database connection (used by the Nest application)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=nest
DATABASE_PASSWORD=nest
DATABASE_NAME=nest

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# AWS S3
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=