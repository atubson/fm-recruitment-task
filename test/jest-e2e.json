{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testMatch": ["<rootDir>/test/**/*.e2e-spec.ts"],
  "setupFiles": ["<rootDir>/test/load-env-e2e.ts"],
  "setupFilesAfterEnv": ["<rootDir>/test/e2e/setup-e2e.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  },
  "forceExit": true,
  "maxWorkers": 1
}
